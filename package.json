{
  "name": "htmx-devtools",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "build:chrome": "vite build && cp manifest.chrome.json dist/manifest.json && cp -r icons dist/",
    "build:firefox": "vite build && cp manifest.firefox.json dist/manifest.json && cp -r icons dist/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@preact/signals": "^1.3.0",
    "@types/chrome": "^0.1.38",
    "preact": "^10.24.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
